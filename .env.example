# API Keys for 6 Target Models - 闭源3个+开源3个

# === 闭源模型 ===

# 1. OpenAI GPT-4o
OPENAI_API_KEY=your_openai_api_key_here

# 2. Anthropic Claude-4.0 (目前最新3.5-Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3. Qwen-Max (阿里闭源版，通过DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# === 开源模型 ===

# 4. DeepSeek-V3 (深度求索)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 5&6. Qwen2.5-72B + Llama-3.2-405B (通过Together AI托管)
TOGETHER_API_KEY=your_together_api_key_here

# Experiment Configuration
EXPERIMENT_NAME=pronoun_evaluation
OUTPUT_DIR=results
CACHE_DIR=cache

# Logging
LOG_LEVEL=INFO